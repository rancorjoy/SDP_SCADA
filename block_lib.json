    "ediv_blk": {
        "input_points": {
            "dividend": "int",
            "divisor": "int"
        },
        "output_points": {
            "quotient": "int",
            "remainder": "int"
        },
        "output_type_case": {
            "quotient": "decltype(dividend_t() / divisor_t())",
            "remainder": "decltype(dividend_t() % divisor_t())"
        },
        "type": "Arithmetic",
        "description": "Divides (Euclidean) dividend / divisor and returns quotient and remainder.",
        "dep_list": [],
        "code_str": "\nif (divisor == 0) {{\n    quotient = 0;\n    remainder = dividend;  // preserves a = bq + r\n}} \nelse {{\n    remainder = dividend % divisor;\n    if (remainder < 0) {{\n        remainder += abs(divisor);\n    }}\n    quotient = (dividend - remainder) / divisor;\n}}\n"
    },

        "dep_list": [],
        "code_str": "\nindex += 1;\nif(index == length)\n{\n    index = 0;\n}\n\narr[index] = reading;\nfloat sum = 0;\nfor (int i=0; i<length; i++)\n{\n    sum += (float)arr[i];\n}\navg = sum/length;\n"
